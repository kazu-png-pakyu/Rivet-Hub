-- ============================================================
local savedCFrames = {}

local function saveCFrame(name)
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	savedCFrames[name] = root.CFrame
	notify("CFrame", "Saved position: " .. name)
end

local function loadCFrame(name)
	local cf = savedCFrames[name]
	if not cf then notify("CFrame","No saved position: "..name) return end
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if root then
		root.CFrame = cf
		notify("CFrame", "Teleported to: " .. name)
	end
end

