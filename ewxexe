-- ===== HELPERS =====
local function notify(title, msg)
	if not settings.notifications then return end
	print("[RivetHub2] " .. title .. ": " .. tostring(msg))
end

local function getPrice(obj)
	for _, name in ipairs({"Price","Cost","TokenPrice","Tokens","BuyPrice","Value"}) do
		local v = obj:FindFirstChild(name)
		if v and (v:IsA("NumberValue") or v:IsA("IntValue")) and v.Value > 0 then
			return v.Value
		end
	end
	for _, child in ipairs(obj:GetChildren()) do
		for _, name in ipairs({"Price","Cost","TokenPrice"}) do
			local v = child:FindFirstChild(name)
			if v and (v:IsA("NumberValue") or v:IsA("IntValue")) and v.Value > 0 then
				return v.Value
			end
		end
	end
	return 0
end

local function getKG(obj)
	for _, name in ipairs({"KG","Kg","kg","Weight","Mass"}) do
		local v = obj:FindFirstChild(name)
		if v and (v:IsA("NumberValue") or v:IsA("IntValue")) then
			return v.Value
		end
	end
	return 0
end

local function teleportTo(obj)
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end
	pcall(function()
		if obj:IsA("BasePart") then
			root.CFrame = obj.CFrame + Vector3.new(0, 5, 0)
		elseif obj:IsA("Model") and obj.PrimaryPart then
			root.CFrame = obj.PrimaryPart.CFrame + Vector3.new(0, 5, 0)
		end
	end)
end

-- ===== SCAN BOOTHS =====
local function scanBooths()
	boothsData     = {}
	stats.totalScans += 1
	local petsToScan = #scanPets > 0 and scanPets or PET_LIST
	local scanSet    = {}
	for _, n in ipairs(petsToScan) do scanSet[n] = true end
	local found = 0
	local seen  = {}
	local descendants = workspace:GetDescendants()
	for i = 1, #descendants, 50 do
		for j = i, math.min(i + 49, #descendants) do
			local obj = descendants[j]
			if obj and not seen[obj] and scanSet[obj.Name] then
				seen[obj] = true
				local price = getPrice(obj)
				local kg    = getKG(obj)
				local passKG = (kg == 0) or (kg >= settings.minKG and kg <= settings.maxKG)
				if price <= settings.maxPrice and passKG then
					found += 1
					local boothName = "Unknown"
					local anc = obj.Parent
					for _ = 1, 4 do
						if anc and anc ~= workspace then
							boothName = anc.Name
							anc = anc.Parent
						else break end
					end
					table.insert(boothsData, {
						Name   = obj.Name,
						Booth  = boothName,
						Price  = price,
						KG     = kg,
						Object = obj,
					})
				end
			end
		end
		task.wait()
	end
	notify("Scan", found .. " pets found in budget")
	return found
end

-- ===== SNIPE LOOP =====
local function snipeLoop()
	while isAutoSniping do
		if #selectedPets == 0 then task.wait(1) continue end
		scanBooths()
		for _, booth in ipairs(boothsData) do
			if not isAutoSniping then break end
			for _, want in ipairs(selectedPets) do
				if booth.Name == want then
					stats.sniped      += 1
					stats.tokensSpent += booth.Price
					table.insert(stats.history, {
						pet   = booth.Name,
						price = booth.Price,
						booth = booth.Booth,
						kg    = booth.KG,
						time  = os.date("%H:%M:%S"),
					})
					if #stats.history > 50 then table.remove(stats.history, 1) end
					notify("SNIPED", booth.Name .. " | " .. booth.Price .. "t | " .. booth.KG .. "kg")
					if settings.autoTeleport and booth.Object then
						teleportTo(booth.Object)
					end
					if settings.autoRejoin then
						task.wait(2)
						TeleportService:Teleport(game.PlaceId, player)
					end
					break
				end
			end
		end
		task.wait(math.max(0.1, 1 / settings.snipeSpeed))
	end
end

local function autoScanLoop()
	while isAutoScanning do
		scanBooths()
		task.wait(5)
	end
end

