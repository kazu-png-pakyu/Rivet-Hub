-- ===== FARM - PLANT SEEDS =====
local function plantSeeds()
	if #selectedSeeds == 0 then notify("Plant","No seeds selected") return end
	local backpack = player:FindFirstChild("Backpack")
	if not backpack then return end
	local plots = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if (obj.Name == "Plot" or obj.Name == "FarmPlot" or obj.Name == "GardenPlot")
			and (obj:IsA("Model") or obj:IsA("BasePart"))
			and not obj:FindFirstChild("Plant")
			and not obj:FindFirstChild("Seed") then
			table.insert(plots, obj)
		end
	end
	local planted = 0
	for _, seedName in ipairs(selectedSeeds) do
		local seed = backpack:FindFirstChild(seedName)
		if seed and #plots > 0 then
			local plot = table.remove(plots, 1)
			pcall(function() PlantRemote:FireServer(seed, plot) end)
			planted += 1
			stats.planted += 1
			task.wait(0.3)
		end
	end
	notify("Plant", "Planted " .. planted .. " seeds")
end

local function autoPlantLoop()
	while isAutoPlanting do
		plantSeeds()
		task.wait(10)
	end
end

