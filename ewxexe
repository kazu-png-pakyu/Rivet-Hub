local function hatchEgg(eggName)
	local backpack = player:FindFirstChild("Backpack")
	if not backpack then return false end
	local egg = backpack:FindFirstChild(eggName)
		or (player.Character and player.Character:FindFirstChild(eggName))
	if not egg then return false end
	local ok = pcall(function()
		PetEggService:FireServer("PlaceEgg", egg)
		task.wait(0.3)
		PetEggService:FireServer("HatchEgg", egg)
	end)
	if ok then
		stats.hatched += 1
		notify("Hatch", "Hatched: " .. eggName)
	end
	return ok
end

local function autoHatchLoop()
	while isAutoHatching do
		if #selectedEggs == 0 then task.wait(1) continue end
		for _, egg in ipairs(selectedEggs) do
			if not isAutoHatching then break end
			hatchEgg(egg)
			task.wait(0.5)
		end
		task.wait(1)
	end
end

