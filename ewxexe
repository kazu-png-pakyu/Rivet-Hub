	notify("Sell", "Fired SellAllPets remote")
end

local function autoSellByFilter()
	local ok, data = pcall(function()
		return DataStream:InvokeServer("GetInventory")
	end)
	if not ok or not data then
		notify("Sell", "Could not get inventory")
		return
	end
	local pets = (data.PetInventory and data.PetInventory.Data) or {}
	local count = 0
	for uuid, petData in pairs(pets) do
		if petData then
			local weight = petData.Weight or petData.Size or 0
			local age    = petData.Age or 0
			local fav    = petData.Favorited or false
			local sell   = false
			if settings.sellWeight > 0 and weight > settings.sellWeight then sell = true end
			if settings.sellAge > 0 and age > settings.sellAge then sell = true end
			if fav and not settings.sellOverrideFav then sell = false end
			if sell then
				sellPetByUUID(uuid)
				count += 1
				task.wait(0.15)
			end
		end
	end
	notify("AutoSell", "Sold " .. count .. " pets")
end

