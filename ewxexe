-- Get all active players in server
local function getActivePlayers()
	local list = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then
			table.insert(list, p.Name)
		end
	end
	return list
end

-- Send a gift to a player using the real PetGiftingModule
local function sendGift(targetPlayer)
	if not PetGiftingModule then
		-- Fallback: fire remote directly
		pcall(function()
			local giftRemote = GameEvents:FindFirstChild("GiftPet")
				or GameEvents:FindFirstChild("PetGiftService")
			if giftRemote then
				giftRemote:FireServer(targetPlayer)
			end
		end)
	else
		pcall(function()
			PetGiftingModule:GivePet(targetPlayer)
		end)
	end
	notify("Gift", "Sent gift to " .. tostring(targetPlayer))
end

-- Get pets from inventory that match gift filters
local function getPetsForGifting()
	local ok, data = pcall(function()
		return DataStream:InvokeServer("GetInventory")
	end)
	if not ok or not data then return {} end

	local pets = (data.PetInventory and data.PetInventory.Data) or {}
	local result = {}

	for uuid, petData in pairs(pets) do
		if petData then
			local weight  = petData.Weight or petData.Size or 0
			local age     = petData.Age or 0
			local fav     = petData.Favorited or false
			local petName = petData.Name or petData.PetName or ""

			-- Skip favorited unless allowed
			if fav and not giftSettings.allowFav then
				continue
			end

			-- Custom mode: only send specific UUIDs
			if giftSettings.customMode then
				for _, customUUID in ipairs(giftSettings.customPetUUIDs) do
					if uuid == customUUID then
						table.insert(result, { uuid = uuid, data = petData })
						break
					end
				end
				continue
			end

			-- Age filter
			if age < giftSettings.minAge or age > giftSettings.maxAge then
				continue
			end

			-- Weight filter
			if weight < giftSettings.minWeight or weight > giftSettings.maxWeight then
				continue
			end

			-- Pet name filter (if list is set)
			if #giftSettings.allowPetList > 0 then
				local allowed = false
				for _, allowedName in ipairs(giftSettings.allowPetList) do
					if petName == allowedName then
						allowed = true
						break
					end
				end
				if not allowed then continue end
			end

			table.insert(result, { uuid = uuid, data = petData })
		end
	end

	return result
end

-- Auto gift loop
local function autoGiftLoop()
	while isGiftRunning do
		if #giftSettings.playerTargets == 0 then
			notify("Gift", "No target players set!")
			task.wait(5)
			continue
		end

		local petsToGift = getPetsForGifting()
		if #petsToGift == 0 then
			notify("Gift", "No pets match gift filters")
			task.wait(5)
			continue
		end

		for _, petInfo in ipairs(petsToGift) do
			if not isGiftRunning then break end

			for _, targetName in ipairs(giftSettings.playerTargets) do
				local targetPlayer = Players:FindFirstChild(targetName)
				if targetPlayer then
					sendGift(targetPlayer)
					task.wait(giftSettings.delayBetweenGift)
				end
			end
		end

		task.wait(2)
	end
end

