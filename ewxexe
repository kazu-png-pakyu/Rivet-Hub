-- Check if a trade UI is currently open
local function isTradeActive()
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return false end
	local tradingUI = gui:FindFirstChild("TradingUI")
	return tradingUI and tradingUI.Enabled == true
end

-- Check if other player is ready in trade
local function isOtherPlayerReady()
	local ok, result = pcall(function()
		local gui = player.PlayerGui
		local ui  = gui:FindFirstChild("TradingUI")
		if not ui then return false end
		local ready = ui.LiveTrade.OtherPlr.Ready.BackgroundTransparency
		return ready and ready < 1
	end)
	return ok and result or false
end

-- Click the Accept button in the trade UI (real UI interaction)
local function clickTradeAccept()
	pcall(function()
		local gui       = player.PlayerGui
		local tradingUI = gui:FindFirstChild("TradingUI")
		if not tradingUI or not tradingUI.Enabled then return end

		local liveTrade = tradingUI:FindFirstChild("LiveTrade")
		local options   = liveTrade and liveTrade:FindFirstChild("Options")
		local acceptBtn = options and options:FindFirstChild("Accept")

		if acceptBtn then
			-- Fire all connections on the button
			for _, conn in ipairs(acceptBtn:GetConnections and acceptBtn:GetConnections() or {}) do
				pcall(function() conn:Fire() end)
			end
			-- Also try simulating a click
			pcall(function()
				local vgui = game:GetService("VirtualInputManager")
				if vgui then
					vgui:SendMouseButtonEvent(
						acceptBtn.AbsolutePosition.X + acceptBtn.AbsoluteSize.X / 2,
						acceptBtn.AbsolutePosition.Y + acceptBtn.AbsoluteSize.Y / 2,
						0, true, game, 1
					)
					task.wait(0.05)
					vgui:SendMouseButtonEvent(
						acceptBtn.AbsolutePosition.X + acceptBtn.AbsoluteSize.X / 2,
						acceptBtn.AbsolutePosition.Y + acceptBtn.AbsoluteSize.Y / 2,
						0, false, game, 1
					)
				end
			end)
		end
	end)
	notify("Trade", "Clicked Accept button")
end

-- Add a pet to the current trade by UUID
local function addPetToTrade(uuid)
	pcall(function()
		ReplicatedStorage.GameEvents.TradeEvents.AddItem:FireServer("Pet", uuid)
	end)
	notify("Trade", "Added pet to trade: " .. tostring(uuid))
end

-- Auto trade accept watcher
local function autoTradeWatcher()
	while isTradeWatcher do
		if isTradeActive() then
			if giftSettings.tradeAutoAccept then
				task.wait(0.5) -- small delay before accepting
				clickTradeAccept()
				notify("Trade", "Auto-accepted trade!")
			end
		end
		task.wait(0.3)
	end
end

