local giftSettings = {
	allowFav         = false,
	tradeAutoAccept  = false,
	customMode       = false,
	delayBetweenGift = 9.9,
	minAge           = 1,
	maxAge           = 2,
	minWeight        = 0.80,
	maxWeight        = 2.86,
	allowPetList     = {},
	customPetUUIDs   = {},
	playerTargets    = {},
}
local isGiftRunning  = false
local isTradeWatcher = false

local PetGiftingModule = nil
pcall(function()
	PetGiftingModule = require(ReplicatedStorage.Modules.PetServices.PetGiftingService)
end)

local function getActivePlayers()
	local list = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player then table.insert(list, p.Name) end
	end
	return list
end

local function sendGift(targetPlayer)
	if PetGiftingModule then
		pcall(function() PetGiftingModule:GivePet(targetPlayer) end)
	else
		pcall(function()
			local r = GameEvents:FindFirstChild("GiftPet") or GameEvents:FindFirstChild("PetGiftService")
			if r then r:FireServer(targetPlayer) end
		end)
	end
	notify("Gift", "Sent gift to " .. tostring(targetPlayer))
end

local function getPetsForGifting()
	local ok, data = pcall(function() return DataStream:InvokeServer("GetInventory") end)
	if not ok or not data then return {} end
	local pets = (data.PetInventory and data.PetInventory.Data) or {}
	local result = {}
	for uuid, petData in pairs(pets) do
		if petData then
			local weight  = petData.Weight or petData.Size or 0
			local age     = petData.Age or 0
			local fav     = petData.Favorited or false
			local petName = petData.Name or petData.PetName or ""
			if fav and not giftSettings.allowFav then continue end
			if giftSettings.customMode then
				for _, cUUID in ipairs(giftSettings.customPetUUIDs) do
					if uuid == cUUID then table.insert(result, {uuid=uuid,data=petData}) break end
				end
				continue
			end
			if age < giftSettings.minAge or age > giftSettings.maxAge then continue end
			if weight < giftSettings.minWeight or weight > giftSettings.maxWeight then continue end
			if #giftSettings.allowPetList > 0 then
				local allowed = false
				for _, n in ipairs(giftSettings.allowPetList) do if petName == n then allowed = true break end end
				if not allowed then continue end
			end
			table.insert(result, {uuid=uuid, data=petData})
		end
	end
	return result
end

local function autoGiftLoop()
	while isGiftRunning do
		if #giftSettings.playerTargets == 0 then task.wait(5) continue end
		local pets = getPetsForGifting()
		if #pets == 0 then task.wait(5) continue end
		for _, petInfo in ipairs(pets) do
			if not isGiftRunning then break end
			for _, targetName in ipairs(giftSettings.playerTargets) do
				local tp = Players:FindFirstChild(targetName)
				if tp then sendGift(tp) task.wait(giftSettings.delayBetweenGift) end
			end
		end
		task.wait(2)
	end
end

local function isTradeActive()
	local gui = player:FindFirstChild("PlayerGui")
	if not gui then return false end
	local ui = gui:FindFirstChild("TradingUI")
	return ui and ui.Enabled == true
end

local function isOtherPlayerReady()
	local ok, result = pcall(function()
		local ui = player.PlayerGui:FindFirstChild("TradingUI")
		if not ui then return false end
		local ready = ui.LiveTrade.OtherPlr.Ready.BackgroundTransparency
		return ready and ready < 1
	end)
	return ok and result or false
end

local function clickTradeAccept()
	pcall(function()
		local tradingUI = player.PlayerGui:FindFirstChild("TradingUI")
		if not tradingUI or not tradingUI.Enabled then return end
		local acceptBtn = tradingUI.LiveTrade.Options:FindFirstChild("Accept")
		if acceptBtn then
			for _, conn in ipairs(acceptBtn:GetConnections and acceptBtn:GetConnections() or {}) do
				pcall(function() conn:Fire() end)
			end
		end
	end)
	notify("Trade", "Clicked Accept")
end

local function addPetToTrade(uuid)
	pcall(function()
		ReplicatedStorage.GameEvents.TradeEvents.AddItem:FireServer("Pet", uuid)
	end)
	notify("Trade", "Added pet to trade")
end

local function autoTradeWatcher()
	while isTradeWatcher do
		if isTradeActive() and giftSettings.tradeAutoAccept then
			task.wait(0.5)
			clickTradeAccept()
			notify("Trade", "Auto-accepted trade!")
		end
		task.wait(0.3)
	end
end

