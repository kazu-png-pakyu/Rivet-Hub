	local function updateVisual()
		tween(track, { BackgroundColor3 = state and THEME.TOGGLE_ON or THEME.TOGGLE_OFF })
		tween(knob, { Position = state and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7) })
	end

	local btn = make("TextButton", {
		Text             = "",
		BackgroundTransparency = 1,
		Size             = UDim2.new(1, 0, 1, 0),
	}, row)
	btn.MouseButton1Click:Connect(function()
		state = not state
		updateVisual()
		if cb then cb(state) end
	end)
end

local function addInput(scroll, title, placeholder, cb)
	local wrap = make("Frame", {
		Size             = UDim2.new(1, 0, 0, 52),
		BackgroundTransparency = 1,
	}, scroll)

	make("TextLabel", {
		Text             = title,
		Font             = FONT_SEMI,
		TextSize         = 11,
		TextColor3       = THEME.TEXT_DIM,
		BackgroundTransparency = 1,
		Size             = UDim2.new(1, 0, 0, 18),
		TextXAlignment   = Enum.TextXAlignment.Left,
	}, wrap)

	local box = make("TextBox", {
		PlaceholderText  = placeholder or "",
		Text             = "",
		Font             = FONT_SEMI,
		TextSize         = 12,
		TextColor3       = THEME.TEXT,
		PlaceholderColor3 = THEME.TEXT_DIM,
		BackgroundColor3 = THEME.INPUT_BG,
		BorderSizePixel  = 0,
		Size             = UDim2.new(1, 0, 0, 28),
		Position         = UDim2.new(0, 0, 0, 20),
		ClearTextOnFocus = false,
	}, wrap)
	corner(6, box)
	stroke(THEME.BORDER, 1, box)
	padding(0, 0, 8, 8, box)

	box.Focused:Connect(function()
		tween(box, { BackgroundColor3 = THEME.ELEMENT })
		stroke(THEME.ACCENT, 1, box)
	end)
	box.FocusLost:Connect(function(enter)
		tween(box, { BackgroundColor3 = THEME.INPUT_BG })
		if enter and cb then cb(box.Text) end
	end)
end

local function addDropdown(scroll, title, values, multi, cb)
	local selected = {}
	local open = false

	local wrap = make("Frame", {
		Size             = UDim2.new(1, 0, 0, 32),
		BackgroundColor3 = THEME.ELEMENT,
		BorderSizePixel  = 0,
		ClipsDescendants = false,
		ZIndex           = 5,
	}, scroll)
	corner(6, wrap)
	stroke(THEME.BORDER, 1, wrap)

	local header = make("TextButton", {
		Text             = title .. " ▾",
		Font             = FONT_SEMI,
		TextSize         = 12,
		TextColor3       = THEME.TEXT,
		BackgroundTransparency = 1,
		Size             = UDim2.new(1, 0, 0, 32),
		TextXAlignment   = Enum.TextXAlignment.Left,
		AutoButtonColor  = false,
		ZIndex           = 6,
	}, wrap)
	padding(0, 0, 10, 10, header)

	local dropdown = make("Frame", {
		Size             = UDim2.new(1, 0, 0, 0),
		Position         = UDim2.new(0, 0, 1, 2),
		BackgroundColor3 = THEME.SECTION,
		BorderSizePixel  = 0,
		ClipsDescendants = true,
		Visible          = false,
		ZIndex           = 10,
	}, wrap)
	corner(6, dropdown)
	stroke(THEME.BORDER, 1, dropdown)

	local ddScroll = make("ScrollingFrame", {
		Size                  = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel       = 0,
		ScrollBarThickness    = 2,
		ScrollBarImageColor3  = THEME.ACCENT,
		CanvasSize            = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize   = Enum.AutomaticSize.Y,
		ZIndex                = 11,
	}, dropdown)
	make("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1) }, ddScroll)

	local function updateHeader()
		if multi then
			header.Text = title .. " (" .. #selected .. " selected) ▾"
		else
			header.Text = title .. " ▾"
		end
	end

	for _, val in ipairs(values) do
		local item = make("TextButton", {
			Text             = val,
			Font             = FONT_SEMI,
			TextSize         = 11,
			TextColor3       = THEME.TEXT_DIM,
			BackgroundColor3 = THEME.SECTION,
			BorderSizePixel  = 0,
			Size             = UDim2.new(1, 0, 0, 26),
			TextXAlignment   = Enum.TextXAlignment.Left,
			AutoButtonColor  = false,
			ZIndex           = 12,
		}, ddScroll)
		padding(0, 0, 8, 8, item)

		item.MouseEnter:Connect(function()
			tween(item, { BackgroundColor3 = THEME.ELEMENT_HOV })
		end)
		item.MouseLeave:Connect(function()
			local isSelected = table.find(selected, val)
			tween(item, { BackgroundColor3 = isSelected and THEME.ACCENT or THEME.SECTION })
		end)

		item.MouseButton1Click:Connect(function()
			if multi then
				local idx = table.find(selected, val)
				if idx then
					table.remove(selected, idx)
					tween(item, { BackgroundColor3 = THEME.SECTION, TextColor3 = THEME.TEXT_DIM })
				else
					table.insert(selected, val)
					tween(item, { BackgroundColor3 = THEME.ACCENT, TextColor3 = Color3.new(1,1,1) })
				end
				updateHeader()
				if cb then cb(selected) end
			else
				selected = { val }
				updateHeader()
				open = false
				dropdown.Visible = false
				wrap.Size = UDim2.new(1, 0, 0, 32)
				if cb then cb(val) end
			end
		end)
	end

	-- Limit dropdown height to 180px
	local ddHeight = math.min(#values * 27, 180)

	header.MouseButton1Click:Connect(function()
		open = not open
		dropdown.Visible = open
		if open then
			dropdown.Size = UDim2.new(1, 0, 0, ddHeight)
			wrap.Size = UDim2.new(1, 0, 0, 32 + ddHeight + 4)
		else
			dropdown.Size = UDim2.new(1, 0, 0, 0)
			wrap.Size = UDim2.new(1, 0, 0, 32)
		end
	end)
end

local function addDivider(scroll)
	make("Frame", {
		Size             = UDim2.new(1, 0, 0, 1),
		BackgroundColor3 = THEME.BORDER,
		BorderSizePixel  = 0,
	}, scroll)
end

-- ===== TAB FACTORY =====
local function createTab(title, icon)
	local btn = createTabButton(title, icon)
	local frame = make("Frame", {
		Size             = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Visible          = false,
	}, ContentArea)

	local scroll, _ = createScrollFrame(frame)

	tabFrames[title]  = frame
	tabButtons[title] = btn

	btn.MouseEnter:Connect(function()
		if activeTab ~= title then
			tween(btn, { BackgroundColor3 = THEME.TAB_HOVER, TextColor3 = THEME.TEXT })
		end
	end)
	btn.MouseLeave:Connect(function()
		if activeTab ~= title then
			tween(btn, { BackgroundColor3 = THEME.TAB_IDLE, TextColor3 = THEME.TEXT_DIM })
		end
	end)
	btn.MouseButton1Click:Connect(function()
		switchTab(title)
	end)

	return {
		Label    = function(_, t)        return addLabel(scroll, t) end,
		Section  = function(_, t)        addSection(scroll, t) end,
		Button   = function(_, t, cb)    addButton(scroll, t, cb) end,
		Toggle   = function(_, t, d, cb) addToggle(scroll, t, d, cb) end,
		Input    = function(_, t, p, cb) addInput(scroll, t, p, cb) end,
		Dropdown = function(_, t, v, m, cb) addDropdown(scroll, t, v, m, cb) end,
		Divider  = function(_)           addDivider(scroll) end,
	}
end

-- Shorthand aliases so existing code works
local function Tab(title, icon) return createTab(title, icon) end

