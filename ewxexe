local showBetterFruitNames = false

local function formatFruitName(name)
	if not showBetterFruitNames then return name end
	-- Remove common suffixes and clean up names
	name = name:gsub("%(Fruit%)", ""):gsub("%(Plant%)", ""):gsub("  ", " ")
	return name:match("^%s*(.-)%s*$") -- trim
end

